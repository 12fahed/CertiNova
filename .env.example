# Environment Variables for CertiNova

# Required: Database Configuration
MONGODB_URI=your-mongodb-atlas-connection-string

# Required: Authentication
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRE=30d

# Required: Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional: Custom Frontend Cloudinary (if different from backend)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-api-key

# Optional: Custom URLs (only needed for custom domains)
# NEXT_PUBLIC_API_URL=https://your-custom-domain.com/api
# NEXT_PUBLIC_FRONTEND_URL=https://your-custom-domain.com

# Example MongoDB Atlas URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/certinova?retryWrites=true&w=majority